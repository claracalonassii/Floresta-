<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Plantio Registrado</title>

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family: Georgia, serif;
    }

    body{
      width:100%;
      height:100vh;
      overflow:hidden;
      background:linear-gradient(180deg,#1f7a2e 0%, #39b54a 100%);
      position:relative;
      display:flex;
      justify-content:center;
      align-items:center;
    }


    /* logo */
    .logo{
      position:absolute;
      top:20px;
      right:20px;
      width:75px;
      height:75px;
      border-radius:50%;
      overflow:hidden;
      cursor:pointer;
      background:white;
    }

    .logo img{
      width:100%;
      height:100%;
      object-fit:cover;
    }

    /* conteúdo central */
    .conteudo{
      display:flex;
      flex-direction:column;
      align-items:center;
      justify-content:center;
      text-align:center;
      z-index:2;
    }

    .check{
      width:140px;
      height:140px;
      border-radius:50%;
      background:#2dd13f;
      display:flex;
      align-items:center;
      justify-content:center;
      font-size:90px;
      color:#1b7c2b;
      margin-bottom:35px;
    }

    h1{
      color:white;
      font-size:60px;
      font-weight:normal;
      line-height:1.2;
      margin-bottom:20px;
    }

    p{
      color:white;
      font-size:30px;
      line-height:1.3;
      margin-bottom:40px;
    }

    .btn{
      width:320px;
      height:70px;
      border:none;
      border-radius:14px;
      background:white;
      color:#2d2d2d;
      font-size:32px;
      cursor:pointer;
      transition:0.2s;
      margin-bottom:20px;
    }

    .btn:hover{
      transform:scale(1.03);
    }

    .inicio{
      color:white;
      text-decoration:none;
      font-size:32px;
      transition:0.2s;
    }

    .inicio:hover{
      text-decoration:underline;
    }

    /* responsivo */
    @media(max-width:768px){

      .folhas-topo,
      .folhas-baixo{
        width:220px;
      }

      .logo{
        width:55px;
        height:55px;
      }

      .check{
        width:100px;
        height:100px;
        font-size:65px;
      }

      h1{
        font-size:34px;
      }

      p{
        font-size:20px;
      }

      .btn{
        width:240px;
        height:55px;
        font-size:22px;
      }

      .inicio{
        font-size:22px;
      }
    }

  </style>
</head>
<body>


  <a href="logo.html" class="logo">
    <img src="https://i.ibb.co/zWPFVrnk/download-2-floresta.png">
  </a>

  <div class="conteudo">

    <div class="check">
      ✓
    </div>

    <h1>
      Plantio registrado <br>
      com sucesso!
    </h1>

    <p>
      Obrigado por contribuir com <br>
      um planeta mais verde.
    </p>


    <button class="btn"
      onclick="window.location.href='relatorios.html'">
      Ver Relatórios
    </button>

    <a href="index.html" class="inicio">
      Voltar ao início
    </a>

  </div>

</body>
</html>
