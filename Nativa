<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nativa</title>
    <style>
     
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }
        body {
            font-family: Arial, sans-serif;
            background-color: #3a7d44;
            color: #fff;
        }

        
        header {
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            padding: 20px;
        }

        header img.logo {
            height: 60px;
            position: absolute;
            left: 20px;
        }

        header h1 {
            font-size: 28px;
        }

 
        .welcome {
            text-align: center;
            margin-bottom: 30px;
        }
        .welcome p:first-child {
            font-weight: bold;
            font-size: 20px;
        }


        .grid-container {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
            padding: 0 20px;
        }

        .card {
            background-color: rgba(255, 255, 255, 0.2);
            border-radius: 10px;
            text-align: center;
            padding: 20px;
            cursor: pointer;
            transition: transform 0.2s, background-color 0.3s;
        }

        .card:hover {
            background-color: rgba(255, 255, 255, 0.4);
            transform: scale(1.05);
        }

        .card img {
            width: 60px;
            margin-bottom: 15px;
        }

        .card h3 {
            margin-bottom: 10px;
        }

        .card p {
            font-size: 14px;
        }


        .logout {
            display: block;
            width: calc(100% - 40px);
            margin: 30px auto;
            padding: 15px 0;
            text-align: center;
            background-color: #fff;
            color: #3a7d44;
            border: none;
            border-radius: 10px;
            font-size: 16px;
            cursor: pointer;
            text-decoration: none;
            transition: background-color 0.3s;
        }

        .logout:hover {
            background-color: #f0f0f0;
        }

        /* ====== RESPONSIVO ====== */
        @media(max-width: 500px){
            .grid-container {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <header>
        <img src="https://i.ibb.co/zWPFVrnk/download-2-floresta.png" alt="Logo Nativa" class="logo">
        <h1>NATIVA</h1>
    </header>

    <div class="welcome">
        <p>Olá, Clara</p>
        <p>Juntos por um planeta mais verde.</p>
    </div>

    <div class="grid-container">
        <div class="card" onclick="goTo('campanhas.html')">
            <img src="https://i.ibb.co/Qv7ZZpyq/download.png" alt="Campanha">
            <h3>Campanha</h3>
            <p>Veja e participe das campanhas</p>
        </div>
        <div class="card" onclick="goTo('plantar.html')">
            <img src="https://i.ibb.co/4ZGKRKBk/download-1.png" alt="Plantar Árvores">
            <h3>Plantar Árvores</h3>
            <p>Registre o plantio de novas Árvores</p>
        </div>
        <div class="card" onclick="goTo('relatorios.html')">
            <img src="https://i.ibb.co/0p3dVkDb/download-2.png" alt="Relatórios">
            <h3>Relatórios</h3>
            <p>Acompanhe o impacto e resultados</p>
        </div>
        <div class="card" onclick="goTo('perfil.html')">
            <img src="https://i.ibb.co/HfTwQqBF/download-3.png" alt="Meu Perfil">
            <h3>Meu Perfil</h3>
            <p>Edite suas informações e preferências</p>
        </div>
    </div>


    <button class="logout" onclick="goTo('sair.html')">Sair</button>

    <script>
        function goTo(page) {
            window.location.href = page;
        }
    </script>
</body>
</html>
